{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "Run SQL Explorer",
      "program": "${workspaceFolder}/.build/debug/SQLExplorer",
      "preLaunchTask": "swift-build",
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Run SQL Explorer (Release)",
      "program": "${workspaceFolder}/.build/release/SQLExplorer",
      "preLaunchTask": "swift-build-release",
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "swift",
      "request": "launch",
      "args": [],
      "cwd": "${workspaceFolder:SqlStudio}",
      "name": "Debug SQLExplorer",
      "target": "SQLExplorer",
      "configuration": "debug",
      "preLaunchTask": "swift: Build Debug SQLExplorer"
    },
    {
      "type": "swift",
      "request": "launch",
      "args": [],
      "cwd": "${workspaceFolder:SqlStudio}",
      "name": "Release SQLExplorer",
      "target": "SQLExplorer",
      "configuration": "release",
      "preLaunchTask": "swift: Build Release SQLExplorer"
    }
  ]
}
