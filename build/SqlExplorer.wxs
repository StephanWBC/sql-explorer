<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
    <Package Name="SQL Explorer"
             Manufacturer="SQL Explorer"
             Version="1.0.0"
             UpgradeCode="F8A3B2C1-4D5E-6F7A-8B9C-0D1E2F3A4B5C">

        <MajorUpgrade DowngradeErrorMessage="A newer version of SQL Explorer is already installed." />
        <MediaTemplate EmbedCab="yes" />

        <Feature Id="ProductFeature" Title="SQL Explorer" Level="1">
            <ComponentGroupRef Id="ProductComponents" />
            <ComponentRef Id="ApplicationShortcut" />
        </Feature>

        <StandardDirectory Id="ProgramFiles6432Folder">
            <Directory Id="INSTALLFOLDER" Name="SQL Explorer">
                <Component Id="ProductComponents" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
                    <File Id="MainExe" Source="$(var.PublishDir)\SqlStudio.App.exe" KeyPath="yes" />
                </Component>
            </Directory>
        </StandardDirectory>

        <StandardDirectory Id="ProgramMenuFolder">
            <Directory Id="ApplicationProgramsFolder" Name="SQL Explorer">
                <Component Id="ApplicationShortcut" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
                    <Shortcut Id="ApplicationStartMenuShortcut"
                              Name="SQL Explorer"
                              Description="Cross-platform SQL Server Management Tool"
                              Target="[INSTALLFOLDER]SqlStudio.App.exe"
                              WorkingDirectory="INSTALLFOLDER" />
                    <RemoveFolder Id="CleanUpShortCut" Directory="ApplicationProgramsFolder" On="uninstall" />
                    <RegistryValue Root="HKCU" Key="Software\SQLExplorer" Name="installed" Type="integer" Value="1" KeyPath="yes" />
                </Component>
            </Directory>
        </StandardDirectory>
    </Package>
</Wix>
