<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Toolbar button: ghost ─────────────────────────────── -->
    <Style Selector="Button.tool">
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="CornerRadius" Value="5"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#C9D1D9"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Opacity" Value="0.8"/>
    </Style>
    <Style Selector="Button.tool:pointerover">
        <Setter Property="Background" Value="#1A21262D"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="Button.tool:pressed">
        <Setter Property="Background" Value="#2521262D"/>
    </Style>
    <Style Selector="Button.tool:disabled">
        <Setter Property="Opacity" Value="0.3"/>
    </Style>

    <!-- ── Toolbar button: primary blue ──────────────────────── -->
    <Style Selector="Button.toolPrimary">
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="CornerRadius" Value="5"/>
        <Setter Property="Background" Value="#238636"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.toolPrimary:pointerover">
        <Setter Property="Background" Value="#2EA043"/>
    </Style>
    <Style Selector="Button.toolPrimary:pressed">
        <Setter Property="Background" Value="#1E7330"/>
    </Style>
    <Style Selector="Button.toolPrimary:disabled">
        <Setter Property="Opacity" Value="0.35"/>
    </Style>

    <!-- ── Toolbar button: execute green ─────────────────────── -->
    <Style Selector="Button.toolExec">
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="CornerRadius" Value="5"/>
        <Setter Property="Background" Value="#1F6FEB"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.toolExec:pointerover">
        <Setter Property="Background" Value="#388BFD"/>
    </Style>
    <Style Selector="Button.toolExec:pressed">
        <Setter Property="Background" Value="#1A5ED1"/>
    </Style>
    <Style Selector="Button.toolExec:disabled">
        <Setter Property="Opacity" Value="0.3"/>
    </Style>

    <!-- ── Label text ────────────────────────────────────────── -->
    <Style Selector="TextBlock.lbl">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="#7D8590"/>
        <Setter Property="Margin" Value="1,0,0,3"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="LetterSpacing" Value="0.5"/>
    </Style>

    <!-- ── Group header in tree ──────────────────────────────── -->
    <Style Selector="TextBlock.groupHeader">
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="#C9D1D9"/>
        <Setter Property="LetterSpacing" Value="0.3"/>
    </Style>

    <!-- ── Environment badge ─────────────────────────────────── -->
    <Style Selector="Border.envBadge">
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="6,1,6,2"/>
        <Setter Property="Margin" Value="6,0,0,0"/>
    </Style>

    <!-- ── Dialog primary button ─────────────────────────────── -->
    <Style Selector="Button.primary">
        <Setter Property="Background" Value="#238636"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="20,8"/>
    </Style>
    <Style Selector="Button.primary:pointerover">
        <Setter Property="Background" Value="#2EA043"/>
    </Style>

    <!-- ── Dialog ghost button ───────────────────────────────── -->
    <Style Selector="Button.ghost">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#8B949E"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style Selector="Button.ghost:pointerover">
        <Setter Property="Background" Value="#1A21262D"/>
    </Style>

</Styles>
