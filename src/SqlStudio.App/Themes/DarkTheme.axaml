<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Core palette ──────────────────────────────────────── -->
    <SolidColorBrush x:Key="AppBg"         Color="#0D1117"/>
    <SolidColorBrush x:Key="SurfaceBg"     Color="#161B22"/>
    <SolidColorBrush x:Key="ExplorerBg"    Color="#0A0F14"/>
    <SolidColorBrush x:Key="EditorBg"      Color="#0D1117"/>
    <SolidColorBrush x:Key="BorderSubtle"  Color="#21262D"/>
    <SolidColorBrush x:Key="BorderMuted"   Color="#161B22"/>

    <!-- ── Text ──────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="TextPrimary"   Color="#E6EDF3"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#8B949E"/>
    <SolidColorBrush x:Key="TextMuted"     Color="#484F58"/>
    <SolidColorBrush x:Key="TextLabel"     Color="#7D8590"/>

    <!-- ── Accent ────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="AccentBlue"    Color="#58A6FF"/>
    <SolidColorBrush x:Key="AccentBlueBg"  Color="#0D2240"/>
    <SolidColorBrush x:Key="SuccessGreen"  Color="#3FB950"/>
    <SolidColorBrush x:Key="SuccessGreenBg" Color="#122117"/>
    <SolidColorBrush x:Key="WarningYellow" Color="#D29922"/>
    <SolidColorBrush x:Key="WarningYellowBg" Color="#2D2410"/>
    <SolidColorBrush x:Key="DangerRed"     Color="#F85149"/>
    <SolidColorBrush x:Key="DangerRedBg"   Color="#2D1518"/>

    <!-- ── Button base ───────────────────────────────────────── -->
    <SolidColorBrush x:Key="BtnPrimary"    Color="#238636"/>
    <SolidColorBrush x:Key="BtnPrimaryHover" Color="#2EA043"/>
    <SolidColorBrush x:Key="BtnSecondary"  Color="#21262D"/>
    <SolidColorBrush x:Key="BtnSecondaryHover" Color="#30363D"/>

    <!-- ── DataGrid ──────────────────────────────────────────── -->
    <SolidColorBrush x:Key="GridAltRow"    Color="#0D1117"/>
    <SolidColorBrush x:Key="GridRow"       Color="#0A0F14"/>
    <SolidColorBrush x:Key="GridHeader"    Color="#161B22"/>
    <SolidColorBrush x:Key="GridLine"      Color="#21262D"/>

</ResourceDictionary>
