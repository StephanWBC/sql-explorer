<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SqlStudio.App.ViewModels"
        x:Class="SqlStudio.App.Views.ConnectionManagerDialog"
        x:DataType="vm:ConnectionManagerViewModel"
        Title="Manage Connections"
        Width="780" Height="600"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        MinWidth="600" MinHeight="400"
        Background="{DynamicResource AppBg}">

    <Grid RowDefinitions="Auto,*,Auto" Margin="0">

        <!-- ── Header toolbar ─────────────────────────────────── -->
        <Border Grid.Row="0" Padding="12,8" Background="{DynamicResource SurfaceBg}"
                BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Manage Connections" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                    <Button Content="+ Group" Command="{Binding CreateGroupCommand}"
                            Classes="toolPrimary" Padding="10,5" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Main content: 2-panel layout ───────────────────── -->
        <Grid Grid.Row="1" ColumnDefinitions="300,Auto,*">

            <!-- Left: Groups + Connections tree -->
            <Border Grid.Column="0" Background="{DynamicResource ExplorerBg}"
                    BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="10,6" Background="{DynamicResource SurfaceBg}"
                            BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,0,1">
                        <TextBlock Text="GROUPS &amp; CONNECTIONS" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMuted}" LetterSpacing="1"/>
                    </Border>
                    <TreeView ItemsSource="{Binding Groups}" Margin="4,4"
                              Background="Transparent">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Connections}">
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2">
                                    <TextBlock Text="{Binding IsUngrouped, Converter={x:Static vm:BoolToGroupIconConverter.Instance}}"
                                               FontSize="12" Opacity="0.6" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Connections.Count, StringFormat='({0})'}" FontSize="10"
                                               Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                        <!-- Connection items inside groups -->
                        <TreeView.Styles>
                            <Style Selector="TreeViewItem TreeViewItem">
                                <Setter Property="IsExpanded" Value="True"/>
                            </Style>
                        </TreeView.Styles>
                    </TreeView>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="2" Background="{DynamicResource BorderSubtle}"/>

            <!-- Right: Selected item details + actions -->
            <Border Grid.Column="2" Padding="16,12" Background="{DynamicResource AppBg}">
                <DockPanel>

                    <!-- Action buttons bar -->
                    <Border DockPanel.Dock="Top" Margin="0,0,0,12">
                        <StackPanel Spacing="8">
                            <!-- Group actions -->
                            <TextBlock Text="GROUP ACTIONS" Classes="lbl" Margin="0,0,0,4"/>
                            <WrapPanel Orientation="Horizontal">
                                <Button Content="+ New Group" Command="{Binding CreateGroupCommand}"
                                        Classes="tool" Margin="0,0,4,4" Padding="10,5"/>
                                <Button Content="Rename" Command="{Binding RenameGroupCommand}"
                                        Classes="tool" Margin="0,0,4,4" Padding="10,5"
                                        IsEnabled="{Binding SelectedGroup, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                <Button Content="Delete Group" Command="{Binding DeleteGroupCommand}"
                                        Classes="tool" Margin="0,0,4,4" Padding="10,5"
                                        IsEnabled="{Binding SelectedGroup, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                            </WrapPanel>

                            <!-- Rename inline -->
                            <StackPanel Orientation="Horizontal" Spacing="6"
                                        IsVisible="{Binding SelectedGroup.IsEditing}">
                                <TextBox Text="{Binding SelectedGroup.EditName}" Width="200" FontSize="13"
                                         CornerRadius="5" Padding="8,5"/>
                                <Button Content="Save" Command="{Binding ConfirmRenameGroupCommand}"
                                        Classes="toolPrimary" Padding="10,5"/>
                            </StackPanel>

                            <Separator Background="{DynamicResource BorderSubtle}" Margin="0,4"/>

                            <!-- Connection actions -->
                            <TextBlock Text="CONNECTION ACTIONS" Classes="lbl" Margin="0,4,0,4"/>
                            <WrapPanel Orientation="Horizontal">
                                <Button Content="Delete Connection" Command="{Binding DeleteConnectionCommand}"
                                        Classes="tool" Margin="0,0,4,4" Padding="10,5"
                                        IsEnabled="{Binding SelectedConnection, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                <Button Content="&#x25B2; Move Up" Command="{Binding MoveConnectionUpCommand}"
                                        Classes="tool" Margin="0,0,4,4" Padding="10,5"
                                        IsEnabled="{Binding SelectedConnection, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                <Button Content="&#x25BC; Move Down" Command="{Binding MoveConnectionDownCommand}"
                                        Classes="tool" Margin="0,0,4,4" Padding="10,5"
                                        IsEnabled="{Binding SelectedConnection, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                            </WrapPanel>

                            <Separator Background="{DynamicResource BorderSubtle}" Margin="0,4"/>

                            <!-- Move to group -->
                            <TextBlock Text="MOVE TO GROUP" Classes="lbl" Margin="0,4,0,4"/>
                            <WrapPanel Orientation="Horizontal">
                                <ItemsControl ItemsSource="{Binding Groups}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ConnectionGroupItem">
                                            <Button Content="{Binding Name}"
                                                    Command="{Binding $parent[Window].((vm:ConnectionManagerViewModel)DataContext).MoveConnectionToGroupCommand}"
                                                    CommandParameter="{Binding}"
                                                    Classes="tool" Margin="0,0,4,4" Padding="10,5" FontSize="11"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </WrapPanel>

                            <Separator Background="{DynamicResource BorderSubtle}" Margin="0,4"/>

                            <!-- Environment label -->
                            <TextBlock Text="SET ENVIRONMENT" Classes="lbl" Margin="0,4,0,4"/>
                            <WrapPanel Orientation="Horizontal">
                                <ItemsControl ItemsSource="{Binding EnvironmentPresets}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding}"
                                                    Command="{Binding $parent[Window].((vm:ConnectionManagerViewModel)DataContext).ChangeEnvironmentCommand}"
                                                    CommandParameter="{Binding}"
                                                    Classes="tool" Margin="0,0,4,4" Padding="8,3" FontSize="11"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Status -->
                    <Border DockPanel.Dock="Bottom">
                        <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                                   Foreground="{DynamicResource TextSecondary}" Margin="0,8,0,0"/>
                    </Border>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ── Footer ─────────────────────────────────────────── -->
        <Border Grid.Row="2" Padding="12,8" Background="{DynamicResource SurfaceBg}"
                BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="11"
                           Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Done" Command="{Binding CloseCommand}"
                        Classes="toolPrimary" Padding="16,6"/>
            </Grid>
        </Border>
    </Grid>
</Window>
