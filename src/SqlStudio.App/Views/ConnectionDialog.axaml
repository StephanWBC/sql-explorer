<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SqlStudio.App.ViewModels"
        x:Class="SqlStudio.App.Views.ConnectionDialog"
        x:DataType="vm:ConnectionDialogViewModel"
        Title="Connect to Server"
        Width="520" Height="580"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">

    <Window.Styles>
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBlock.lbl">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#7788AA"/>
            <Setter Property="Margin" Value="1,0,0,2"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,8"/>
        </Style>
        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8899BB"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Styles>

    <Border Padding="20,12,20,16">
        <Border.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Offset="0" Color="#0F1318"/>
                <GradientStop Offset="1" Color="#151B24"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid RowDefinitions="Auto,*,Auto">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,14">
                <Viewbox Width="30" Height="30">
                    <Canvas Width="64" Height="64">
                        <Ellipse Canvas.Left="8" Canvas.Top="8" Width="48" Height="16" Fill="#0078D4"/>
                        <Rectangle Canvas.Left="8" Canvas.Top="16" Width="48" Height="32" Fill="#0078D4"/>
                        <Ellipse Canvas.Left="8" Canvas.Top="40" Width="48" Height="16" Fill="#005A9E"/>
                        <Ellipse Canvas.Left="36" Canvas.Top="34" Width="18" Height="18" Stroke="White" StrokeThickness="2.5" Fill="Transparent"/>
                        <Line StartPoint="51,49" EndPoint="58,56" Stroke="White" StrokeThickness="2.5" StrokeLineCap="Round"/>
                    </Canvas>
                </Viewbox>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Connect to Server" FontSize="17" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Azure SQL  ·  Local  ·  Docker" FontSize="11" Foreground="#556677"/>
                </StackPanel>
            </StackPanel>

            <!-- Form -->
            <ScrollViewer Grid.Row="1" Padding="0,0,4,0">
                <StackPanel Spacing="12">

                    <!-- Saved Connections -->
                    <StackPanel Spacing="4" IsVisible="{Binding SavedConnections.Count}">
                        <TextBlock Text="SAVED CONNECTIONS" Classes="lbl"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding SavedConnections}"
                                      SelectedItem="{Binding SelectedSavedConnection}"
                                      PlaceholderText="Select a saved connection..."
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Grid.Column="1" Content="&#x2715;" Margin="6,0,0,0"
                                    Classes="ghost" ToolTip.Tip="Delete saved connection"
                                    Command="{Binding DeleteSavedConnectionCommand}"
                                    IsEnabled="{Binding SelectedSavedConnection, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                        </Grid>
                        <Separator Margin="0,4,0,0" Background="#1A2030"/>
                    </StackPanel>

                    <!-- Server row -->
                    <Grid ColumnDefinitions="*,90">
                        <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,8,0">
                            <TextBlock Text="SERVER" Classes="lbl"/>
                            <TextBox Text="{Binding ServerName}" Watermark="myserver.database.windows.net"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="PORT" Classes="lbl"/>
                            <NumericUpDown Value="{Binding Port}" Minimum="1" Maximum="65535"
                                           FormatString="0" FontSize="13" CornerRadius="6"/>
                        </StackPanel>
                    </Grid>

                    <!-- Auth method -->
                    <StackPanel Spacing="2">
                        <TextBlock Text="AUTHENTICATION" Classes="lbl"/>
                        <ComboBox ItemsSource="{Binding AuthTypes}"
                                  SelectedItem="{Binding AuthType}"
                                  HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <!-- SQL Auth fields -->
                    <Grid ColumnDefinitions="*,*" IsVisible="{Binding IsSqlAuth}">
                        <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,6,0">
                            <TextBlock Text="USERNAME" Classes="lbl"/>
                            <TextBox Text="{Binding Username}" Watermark="sa"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2" Margin="6,0,0,0">
                            <TextBlock Text="PASSWORD" Classes="lbl"/>
                            <TextBox Text="{Binding Password}" PasswordChar="&#x2022;" Watermark="&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;"/>
                        </StackPanel>
                    </Grid>

                    <!-- Entra ID section -->
                    <StackPanel IsVisible="{Binding IsEntraAuth}" Spacing="8">

                        <!-- Sign-in button when not signed in -->
                        <Border IsVisible="{Binding !IsEntraSignedIn}"
                                Background="#0C1A28" CornerRadius="8" Padding="14,12"
                                BorderBrush="#152535" BorderThickness="1">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <TextBlock Text="Sign in to see your databases" FontSize="12"
                                           Foreground="#556677" HorizontalAlignment="Center"/>
                                <Button Command="{Binding SignInWithEntraCommand}"
                                        IsEnabled="{Binding !IsSigningIn}"
                                        HorizontalAlignment="Center" Classes="primary" Padding="22,8">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="&#x1F310;" FontSize="14" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding IsSigningIn, Converter={x:Static vm:BoolToSignInTextConverter.Instance}}"
                                                   VerticalAlignment="Center" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Signed in banner -->
                        <Border IsVisible="{Binding IsEntraSignedIn}"
                                Background="#0A1F0F" CornerRadius="8" Padding="12,8"
                                BorderBrush="#1A3A1A" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="&#x2705;" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding EntraUserEmail}" FontSize="13"
                                           Foreground="#66CC66" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Database list after sign-in -->
                        <StackPanel IsVisible="{Binding IsEntraSignedIn}" Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="SELECT DATABASE" Classes="lbl"/>
                                <Button Command="{Binding RefreshDatabasesCommand}" Classes="ghost"
                                        Content="&#x21BB;" FontSize="13" Padding="4,2"
                                        ToolTip.Tip="Refresh database list"/>
                            </StackPanel>
                            <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoadingDatabases}"
                                         Height="2" Margin="0,0,0,2"/>
                            <ListBox ItemsSource="{Binding AvailableDatabases}"
                                     SelectedItem="{Binding SelectedDatabase}"
                                     MaxHeight="130" CornerRadius="6"
                                     Background="#0A0F14" BorderBrush="#1A2030" BorderThickness="1">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="2,1">
                                            <TextBlock Text="&#x1F4BE;" FontSize="11" VerticalAlignment="Center" Opacity="0.5"/>
                                            <TextBlock Text="{Binding}" FontSize="13"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </StackPanel>

                    <!-- Database (for SQL auth or manual override) -->
                    <StackPanel Spacing="2" IsVisible="{Binding IsSqlAuth}">
                        <TextBlock Text="DATABASE" Classes="lbl"/>
                        <TextBox Text="{Binding DatabaseName}" Watermark="master"/>
                    </StackPanel>

                    <!-- Connection name -->
                    <StackPanel Spacing="2">
                        <TextBlock Text="CONNECTION NAME (optional)" Classes="lbl"/>
                        <TextBox Text="{Binding ConnectionName}" Watermark="e.g. Production, Dev Server"/>
                    </StackPanel>

                    <!-- Options row -->
                    <WrapPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <CheckBox IsChecked="{Binding TrustServerCertificate}" Content="Trust Certificate" Margin="0,0,14,0" FontSize="12"/>
                        <CheckBox IsChecked="{Binding Encrypt}" Content="Encrypt" Margin="0,0,14,0" FontSize="12"/>
                        <CheckBox IsChecked="{Binding SaveConnection}" Content="Save connection" FontSize="12"/>
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <StackPanel Grid.Row="2" Spacing="8" Margin="0,10,0,0">
                <!-- Status banner -->
                <Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        CornerRadius="6" Padding="10,7"
                        Background="{Binding IsStatusError, Converter={x:Static vm:BoolToStatusBgConverter.Instance}}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{Binding IsStatusError, Converter={x:Static vm:BoolToStatusIconConverter.Instance}}"
                                   FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusMessage}" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{Binding IsStatusError, Converter={x:Static vm:BoolToErrorColorConverter.Instance}}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Buttons -->
                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                    <Button Grid.Column="0" Command="{Binding TestConnectionCommand}"
                            IsEnabled="{Binding !IsTesting}" Classes="ghost">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="&#x26A1;" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding IsTesting, Converter={x:Static vm:BoolToTestTextConverter.Instance}}"
                                       VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2" Command="{Binding ConnectCommand}"
                            IsEnabled="{Binding !IsConnecting}" Classes="primary">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="{Binding IsConnecting, Converter={x:Static vm:BoolToConnectTextConverter.Instance}}"
                                       VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="3" Content="Cancel" Command="{Binding CancelCommand}"
                            Classes="ghost" Margin="6,0,0,0"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
