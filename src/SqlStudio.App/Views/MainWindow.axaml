<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SqlStudio.App.ViewModels"
        x:Class="SqlStudio.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Icon="/Assets/logo.png"
        Width="1400" Height="900"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Connect" Command="{Binding ConnectCommand}" InputGesture="Ctrl+N" />
                <MenuItem Header="_Disconnect" Command="{Binding DisconnectCommand}" IsEnabled="{Binding IsConnected}" />
                <Separator />
                <MenuItem Header="_New Query" Command="{Binding NewQueryCommand}" IsEnabled="{Binding IsConnected}" InputGesture="Ctrl+T" />
                <MenuItem Header="Close _Tab" Command="{Binding CloseTabCommand}" InputGesture="Ctrl+W" />
                <Separator />
                <MenuItem Header="E_xport Results to CSV" Command="{Binding ExportResultsCommand}" />
            </MenuItem>
            <MenuItem Header="_Query">
                <MenuItem Header="_Execute" Command="{Binding ExecuteQueryCommand}" IsEnabled="{Binding IsConnected}" InputGesture="F5" />
                <MenuItem Header="C_ancel" Command="{Binding CancelQueryCommand}" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Toggle _Theme" Command="{Binding ToggleThemeCommand}" />
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource SystemChromeMediumColor}" Padding="4">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <!-- App Logo -->
                <Viewbox Width="28" Height="28" Margin="2,0,8,0">
                    <Canvas Width="64" Height="64">
                        <!-- Database cylinder body -->
                        <Ellipse Canvas.Left="8" Canvas.Top="8" Width="48" Height="16" Fill="#0078D4" />
                        <Rectangle Canvas.Left="8" Canvas.Top="16" Width="48" Height="32" Fill="#0078D4" />
                        <Ellipse Canvas.Left="8" Canvas.Top="40" Width="48" Height="16" Fill="#005A9E" />
                        <!-- Top ellipse highlight -->
                        <Ellipse Canvas.Left="12" Canvas.Top="10" Width="40" Height="12" Fill="#2B88D8" />
                        <!-- Middle line -->
                        <Line StartPoint="8,28" EndPoint="56,28" Stroke="#005A9E" StrokeThickness="1" />
                        <!-- Search magnifier -->
                        <Ellipse Canvas.Left="36" Canvas.Top="34" Width="18" Height="18" Stroke="White" StrokeThickness="2.5" Fill="Transparent" />
                        <Line StartPoint="51,49" EndPoint="58,56" Stroke="White" StrokeThickness="2.5" StrokeLineCap="Round" />
                    </Canvas>
                </Viewbox>

                <TextBlock Text="SQL Explorer" VerticalAlignment="Center" FontWeight="SemiBold"
                           FontSize="15" Margin="0,0,12,0" Foreground="{DynamicResource SystemBaseHighColor}" />

                <Button Content="Connect" Command="{Binding ConnectCommand}"
                        Classes="accent" Padding="12,6" />
                <Button Content="Disconnect" Command="{Binding DisconnectCommand}"
                        IsEnabled="{Binding IsConnected}" Padding="12,6" />

                <Border Width="1" Background="{DynamicResource SystemBaseMediumLowColor}" Margin="4,2" />

                <Button Content="New Query" Command="{Binding NewQueryCommand}"
                        IsEnabled="{Binding IsConnected}" Padding="12,6" />

                <Border Width="1" Background="{DynamicResource SystemBaseMediumLowColor}" Margin="4,2" />

                <Button Content="&#9654; Execute" Command="{Binding ExecuteQueryCommand}"
                        IsEnabled="{Binding IsConnected}" Padding="12,6" FontWeight="Bold" Classes="accent" />
                <Button Content="Cancel" Command="{Binding CancelQueryCommand}"
                        Padding="12,6" />

                <Border Width="1" Background="{DynamicResource SystemBaseMediumLowColor}" Margin="4,2" />

                <Button Content="Export CSV" Command="{Binding ExportResultsCommand}"
                        Padding="12,6" />

                <Border Width="1" Background="{DynamicResource SystemBaseMediumLowColor}" Margin="4,2" />

                <Button Command="{Binding ToggleThemeCommand}" Padding="12,6" ToolTip.Tip="Toggle Dark/Light Theme">
                    <TextBlock Text="&#x263C;" FontSize="16" />
                </Button>
            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Padding="8,4" Background="{DynamicResource SystemChromeMediumColor}">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusBarText}" VerticalAlignment="Center" FontSize="12" />
                <TextBlock Grid.Column="1" Text="{Binding ConnectionStatus}" Margin="16,0"
                           VerticalAlignment="Center" FontSize="12" />
                <TextBlock Grid.Column="2" Text="{Binding CurrentDatabase, StringFormat='Database: {0}'}"
                           Margin="16,0" VerticalAlignment="Center" FontSize="12"
                           IsVisible="{Binding IsConnected}" />
                <TextBlock Grid.Column="3" Text="{Binding ActiveConnectionName}"
                           Margin="16,0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"
                           IsVisible="{Binding IsConnected}" />
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid ColumnDefinitions="280,Auto,*">
            <!-- Object Explorer -->
            <Border Grid.Column="0" Padding="4">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Object Explorer" FontWeight="Bold"
                               FontSize="14" Margin="4,4,4,8" />
                    <TreeView ItemsSource="{Binding ObjectExplorerNodes}"
                              x:Name="ObjectExplorerTree">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding ObjectType, Converter={x:Static vm:ObjectTypeToIconConverter.Instance}}"
                                               FontFamily="Segoe UI Symbol, Apple Symbols, sans-serif"
                                               FontSize="14" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                    <ProgressBar IsVisible="{Binding IsLoading}"
                                                 IsIndeterminate="True" Width="60" Height="4" Margin="4,0,0,0" />
                                </StackPanel>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" ResizeDirection="Columns" />

            <!-- Query Area -->
            <Grid Grid.Column="2" RowDefinitions="*">
                <TabControl ItemsSource="{Binding QueryTabs}"
                            SelectedItem="{Binding SelectedTab}"
                            Padding="0">
                    <TabControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:QueryTabViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{Binding Title}" />
                                <Button Content="x" FontSize="10" Padding="2"
                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CloseTabCommand}"
                                        Classes="transparent" />
                            </StackPanel>
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:QueryTabViewModel">
                            <Grid RowDefinitions="*,Auto,*">
                                <!-- SQL Editor -->
                                <Border Grid.Row="0" Margin="4" BorderBrush="{DynamicResource SystemBaseMediumLowColor}" BorderThickness="1" CornerRadius="4">
                                    <TextBox Text="{Binding SqlText}"
                                             AcceptsReturn="True"
                                             AcceptsTab="True"
                                             TextWrapping="NoWrap"
                                             FontFamily="Cascadia Code, JetBrains Mono, Consolas, monospace"
                                             FontSize="14"
                                             Watermark="Enter SQL query here... (F5 to execute)"
                                             MinHeight="150" />
                                </Border>

                                <!-- Horizontal Splitter -->
                                <GridSplitter Grid.Row="1" Height="4" ResizeDirection="Rows" />

                                <!-- Results Area -->
                                <Border Grid.Row="2" Margin="4">
                                    <TabControl SelectedIndex="{Binding SelectedResultsTab}">
                                        <TabItem Header="Results">
                                            <DataGrid ItemsSource="{Binding ResultData.DefaultView}"
                                                      IsReadOnly="True"
                                                      CanUserReorderColumns="True"
                                                      CanUserResizeColumns="True"
                                                      CanUserSortColumns="True"
                                                      GridLinesVisibility="All"
                                                      BorderThickness="1"
                                                      BorderBrush="{DynamicResource SystemBaseMediumLowColor}"
                                                      FontFamily="Cascadia Code, JetBrains Mono, Consolas, monospace"
                                                      FontSize="12"
                                                      AutoGenerateColumns="True"
                                                      IsVisible="{Binding HasResults}" />
                                        </TabItem>
                                        <TabItem Header="Messages">
                                            <TextBox Text="{Binding MessagesText}"
                                                     IsReadOnly="True"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     FontFamily="Cascadia Code, JetBrains Mono, Consolas, monospace"
                                                     FontSize="13"
                                                     Foreground="{DynamicResource SystemBaseHighColor}" />
                                        </TabItem>
                                    </TabControl>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>

                <!-- Placeholder when no tabs -->
                <Border IsVisible="{Binding !QueryTabs.Count}"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel Spacing="12" HorizontalAlignment="Center">
                        <Viewbox Width="80" Height="80" Opacity="0.3">
                            <Canvas Width="64" Height="64">
                                <Ellipse Canvas.Left="8" Canvas.Top="8" Width="48" Height="16" Fill="{DynamicResource SystemBaseHighColor}" />
                                <Rectangle Canvas.Left="8" Canvas.Top="16" Width="48" Height="32" Fill="{DynamicResource SystemBaseHighColor}" />
                                <Ellipse Canvas.Left="8" Canvas.Top="40" Width="48" Height="16" Fill="{DynamicResource SystemBaseMediumColor}" />
                                <Ellipse Canvas.Left="36" Canvas.Top="34" Width="18" Height="18" Stroke="{DynamicResource SystemBaseHighColor}" StrokeThickness="2.5" Fill="Transparent" />
                                <Line StartPoint="51,49" EndPoint="58,56" Stroke="{DynamicResource SystemBaseHighColor}" StrokeThickness="2.5" StrokeLineCap="Round" />
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="SQL Explorer" FontSize="24" FontWeight="Light"
                                   HorizontalAlignment="Center" Opacity="0.5" />
                        <TextBlock Text="Connect to a server and open a new query tab to get started."
                                   FontSize="14" HorizontalAlignment="Center" Opacity="0.4" />
                        <TextBlock Text="Ctrl+N to connect  |  Ctrl+T for new query  |  F5 to execute"
                                   FontSize="12" HorizontalAlignment="Center" Opacity="0.3" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
